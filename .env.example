# CockroachDB Cloud -- Console > Connect > General connection string
DATABASE_URL=postgresql://user:password@cluster-host:26257/incident_copilot?sslmode=verify-full

# AWS / Bedrock (models must be enabled in this region)
AWS_REGION=us-east-1
# Any Bedrock model with tool use. Nova is first-party (no Marketplace
# subscription needed); Anthropic models require one plus valid billing.
CHAT_MODEL_ID=us.amazon.nova-pro-v1:0
EMBED_MODEL_ID=amazon.titan-embed-text-v2:0
EMBED_DIMS=1024

# Retrieval tuning
RECALL_K=4
RECALL_MAX_DISTANCE=0.70

# Optional: S3 bucket for postmortem documents
S3_BUCKET=
